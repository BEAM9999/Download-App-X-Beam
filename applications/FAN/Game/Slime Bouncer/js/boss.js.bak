/* ══════════════════════════════════════════════
   Slime Bouncer — Boss System
   Boss 1: Thornback (World 1, Level 1-5)
   ═════════════════════════════════════════════ */
'use strict';
(function() {
const SB = window.SB || (window.SB = {});
const U = SB.Utils;

class Boss {
  constructor(x, y, type) {
    this.x = x; this.y = y; this.type = type;
    this.active = false; // activated when player enters arena
    this.defeated = false;
    this.phase = 1;
    this.frame = 0; this.frameTimer = 0;
    this.flashTimer = 0;
    this.stateTimer = 0;
    this.attackState = 'idle'; // idle, telegraph, attack, vulnerable, transition
    this.attackIndex = 0;
    this.projectiles = [];
    this.vulnerable = false;
    this.vulnTimer = 0;
    this.activated = false;

    const cfg = Boss.TYPES[type] || Boss.TYPES.thornback;
    this.w = cfg.w; this.h = cfg.h;
    this.hp = cfg.hp; this.maxHp = cfg.hp;
    this.color = cfg.color;
    this.name = cfg.name;
    this.arenaX = 0; // set when activated
  }

  get alive() { return this.active && !this.defeated; }
  set alive(v) { if (!v) { this.active = false; this.defeated = true; } }

  activate(arenaX) {
    this.active = true;
    this.arenaX = arenaX;
    this.attackState = 'idle';
    this.stateTimer = 2;
    SB.Audio.sfx('bossPhase');
  }

  update(dt, player) {
    if (!this.active || this.defeated) return;
    this.frameTimer += dt;
    if (this.frameTimer > 0.2) { this.frameTimer = 0; this.frame = (this.frame + 1) % 4; }
    if (this.flashTimer > 0) this.flashTimer -= dt;

    // Update based on type — all bosses use same attack pattern framework
    this._updateAttackPattern(dt, player);

    // Update projectiles
    for (let i = this.projectiles.length - 1; i >= 0; i--) {
      const p = this.projectiles[i];
      p.x += p.vx * dt;
      p.y += p.vy * dt;
      if (p.gravity) p.vy += p.gravity * dt;
      p.life -= dt;
      if (p.life <= 0) this.projectiles.splice(i, 1);
    }
  }

  // ── Generic Boss Attack Pattern ──
  _updateAttackPattern(dt, player) {
    this.stateTimer -= dt;

    if (this.stateTimer <= 0) {
      switch (this.attackState) {
        case 'idle':
          this.attackState = 'attack';
          this.attackIndex = (this.attackIndex + 1) % 3;
          if (this.attackIndex === 0) {
            // Vine sweep
            this.stateTimer = 1;
            this._vineAttack(player);
          } else if (this.attackIndex === 1) {
            // Thorn shot
            this.stateTimer = 0.8;
            this._thornShot(player);
          } else {
            // Root attack (phase 2 only)
            if (this.phase >= 2) {
              this.stateTimer = 1.2;
              this._rootAttack(player);
            } else {
              this.attackState = 'vulnerable';
              this.stateTimer = this.phase >= 2 ? 1.5 : 2;
              this.vulnerable = true;
            }
          }
          break;

        case 'attack':
          this.attackState = 'vulnerable';
          this.stateTimer = this.phase >= 2 ? 1.5 : 2;
          this.vulnerable = true;
          break;

        case 'vulnerable':
          this.vulnerable = false;
          this.attackState = 'idle';
          this.stateTimer = 1;
          break;

        case 'transition':
          this.attackState = 'idle';
          this.stateTimer = 2;
          break;
      }
    }
  }

  _vineAttack(player) {
    // Vines shoot toward the player
    const dir = player.x < this.x + this.w / 2 ? -1 : 1;
    for (let i = 0; i < 3; i++) {
      this.projectiles.push({
        x: dir > 0 ? this.x + this.w : this.x,
        y: this.y + 20 + i * 35,
        vx: dir * 160,
        vy: 20 + i * 15,
        gravity: 40,
        life: 3.5, w: 20, h: 6, color: '#27ae60'
      });
    }
  }

  _thornShot(player) {
    // Aim thorn spread at the player's current position
    const count = this.phase >= 2 ? 5 : 3;
    const dx = player.x - (this.x + this.w / 2);
    const dy = player.y - (this.y + this.h / 2);
    const baseAngle = Math.atan2(dy, dx);
    const speed = 150;
    for (let i = 0; i < count; i++) {
      const spread = (i - (count - 1) / 2) * 0.25;
      const angle = baseAngle + spread;
      this.projectiles.push({
        x: this.x + this.w / 2, y: this.y + this.h / 2,
        vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed,
        gravity: 80, life: 3.5, w: 6, h: 6, color: '#8B4513'
      });
    }
  }

  _rootAttack(player) {
    // Roots from ground at player position
    for (let i = 0; i < 3; i++) {
      const rx = player.x + U.randFloat(-60, 60);
      setTimeout(() => {
        if (this.defeated) return;
        this.projectiles.push({
          x: rx, y: SB.H - 80,
          vx: 0, vy: -250, gravity: 0,
          life: 0.8, w: 8, h: 40, color: '#8B4513'
        });
      }, i * 300);
    }
  }

  hit(dmg) {
    if (!this.vulnerable && !this.defeated) return false;
    this.hp -= (dmg || 1);
    this.flashTimer = 0.2;
    SB.Audio.sfx('bossHit');
    SB.Camera.shake(4, 0.2);

    // Check phase transition (all bosses transition at 50% HP)
    if (this.hp <= Math.floor(this.maxHp / 2) && this.phase === 1) {
      this.phase = 2;
      this.attackState = 'transition';
      this.stateTimer = 2;
      this.vulnerable = false;
      SB.Audio.sfx('bossPhase');
      SB.Camera.shake(6, 0.5);
    }

    if (this.hp <= 0) {
      this.defeated = true;
      this.active = false;
      SB.Particles.emit('bossExplosion', this.x + this.w / 2, this.y + this.h / 2);
      SB.Audio.sfx('bossDie');
      SB.Camera.shake(8, 1);
      return true;
    }
    return false;
  }

  draw(ctx, cam) {
    if (!this.active || this.defeated) return;
    const sx = Math.round(this.x - cam.x);
    const sy = Math.round(this.y - cam.y);

    // Flash when hit
    if (this.flashTimer > 0 && Math.floor(this.flashTimer * 20) % 2 === 0) {
      ctx.fillStyle = '#fff';
    } else {
      ctx.fillStyle = this.color;
    }

    // Body
    ctx.fillRect(sx + 20, sy + 20, this.w - 40, this.h - 20);

    // Type-specific visuals
    const armBob = Math.sin(Date.now() / 300) * 5;
    if (this.type === 'thornback') {
      // Canopy
      ctx.fillStyle = this.phase >= 2 ? '#6c3483' : '#27ae60';
      ctx.fillRect(sx, sy, this.w, 50);
      ctx.fillRect(sx + 10, sy - 10, this.w - 20, 20);
      // Vines
      ctx.fillStyle = '#2ecc71';
      ctx.fillRect(sx - 20, sy + 40 + armBob, 25, 8);
      ctx.fillRect(sx + this.w - 5, sy + 40 - armBob, 25, 8);
    } else if (this.type === 'sand_wyrm') {
      // Segments
      ctx.fillStyle = this.phase >= 2 ? '#b8860b' : '#daa520';
      ctx.fillRect(sx, sy + 10, this.w, 30);
      ctx.fillRect(sx + 10, sy, this.w - 20, 10);
      // Mandibles
      ctx.fillStyle = '#8B0000';
      ctx.fillRect(sx - 15, sy + 15 + armBob, 20, 6);
      ctx.fillRect(sx + this.w - 5, sy + 15 - armBob, 20, 6);
    } else if (this.type === 'frost_giant') {
      // Crown
      ctx.fillStyle = this.phase >= 2 ? '#ff6b6b' : '#a8d8ea';
      for (let i = 0; i < 5; i++) ctx.fillRect(sx + 10 + i * 18, sy - 15, 10, 20);
      // Armor
      ctx.fillStyle = '#5f9ea0';
      ctx.fillRect(sx + 10, sy + 40, this.w - 20, 50);
      // Arms
      ctx.fillRect(sx - 15, sy + 30 + armBob, 20, 12);
      ctx.fillRect(sx + this.w - 5, sy + 30 - armBob, 20, 12);
    } else if (this.type === 'shadow_king') {
      // Crown
      ctx.fillStyle = '#f1c40f';
      for (let i = 0; i < 5; i++) ctx.fillRect(sx + 15 + i * 20, sy - 12, 8, 16);
      // Cape
      ctx.fillStyle = this.phase >= 2 ? '#8e44ad' : '#2c3e50';
      ctx.fillRect(sx + 5, sy + 50, this.w - 10, this.h - 60);
      // Arms
      ctx.fillRect(sx - 18, sy + 40 + armBob, 25, 10);
      ctx.fillRect(sx + this.w - 7, sy + 40 - armBob, 25, 10);
    }

    // Face (all bosses)
    ctx.fillStyle = this.phase >= 2 ? '#e74c3c' : '#8e44ad';
    ctx.fillRect(sx + 35, sy + 55, 12, 12); // left eye
    ctx.fillRect(sx + this.w - 47, sy + 55, 12, 12); // right eye
    ctx.fillStyle = '#2c3e50';
    ctx.fillRect(sx + 30, sy + 80, this.w - 60, 8); // mouth

    // Vulnerable indicator
    if (this.vulnerable) {
      ctx.fillStyle = '#e74c3c';
      const weakX = sx + this.w / 2 - 6;
      const weakY = sy + 5 + Math.sin(Date.now() / 200) * 3;
      ctx.fillRect(weakX, weakY, 12, 12);
      ctx.fillStyle = '#f39c12';
      ctx.fillRect(weakX + 2, weakY + 2, 8, 8);
    }

    // Draw projectiles
    for (const p of this.projectiles) {
      ctx.fillStyle = p.color || '#8B4513';
      ctx.fillRect(Math.round(p.x - cam.x), Math.round(p.y - cam.y), p.w, p.h);
    }
  }
}

Boss.TYPES = {
  thornback: { w: 128, h: 140, hp: 12, color: '#8B4513', name: 'Thornback' },
  sand_wyrm: { w: 100, h: 60, hp: 18, color: '#d4a017', name: 'Sand Wyrm' },
  frost_giant:{ w: 96, h: 128, hp: 24, color: '#74b9ff', name: 'Frost Giant' },
  shadow_king:{ w: 120, h: 160, hp: 36, color: '#2c3e50', name: 'Shadow King' }
};

SB.Boss = Boss;
SB.boss = null;
})();
